# Cante — environment configuration
# Copy this to .env and fill in your values. Never commit .env.
#
# IMPORTANT: the app refuses to start (S4) while any secret below is empty or
# still a shipped default. Generate real values before first boot.

# ── App ────────────────────────────────────────
DEBUG=false
DEFAULT_LANGUAGE=en
# Comma-separated allowed CORS origins for the backoffice frontend (S8).
# Empty = same-origin only. Example: https://cante.example.com,https://admin.example.com
CORS_ORIGINS=

# ── Auth (backoffice login + machine tokens) ───
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# A SEPARATE key for the POST /v1/triggers machine endpoint (NOT the JWT secret).
TRIGGER_API_KEY=
ADMIN_EMAIL=admin@example.com
# Set a real password; the default "change-me" is refused at startup.
ADMIN_PASSWORD=

# ── Database ───────────────────────────────────
POSTGRES_USER=cante
POSTGRES_PASSWORD=
POSTGRES_DB=cante
# Built by compose from the values above; override only for external Postgres.
DATABASE_URL=postgresql+asyncpg://cante:${POSTGRES_PASSWORD}@postgres:5432/cante

# ── Redis ──────────────────────────────────────
# Set REDIS_PASSWORD to enable Redis ACL (S17). Leave empty for local dev only.
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── LLM providers (fallback keys — prefer the Providers page in the backoffice) ─
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Evolution API (WhatsApp gateway) ───────────
EVOLUTION_BASE_URL=http://evolution:8080
EVOLUTION_API_KEY=

# ── Secrets encryption (at rest) ───────────────
# MUST be a valid Fernet key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# ── Observability (optional) ───────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# ── Domain (for production edge proxy) ──────────
PUBLIC_DOMAIN=localhost
