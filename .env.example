# Cante — environment configuration
# Copy this to .env and fill in your values. Never commit .env.
#
# IMPORTANT: the app refuses to start (S4) while any secret below is empty or
# still a shipped default. Generate real values before first boot.

# ── Instance isolation ─────────────────────────
# Run several cante forks side-by-side on the same host (one fork per
# deployment, e.g. one per club / per product). Leave INSTANCE empty for the
# default single-instance "cante*" setup. Set INSTANCE (e.g. "cds") to prefix
# ALL compose resources so a second instance does NOT collide with the first:
#   project / network / volume -> cante-<INSTANCE>_...
#   container names            -> cante-<INSTANCE>-<service>
# Each instance MUST also use a UNIQUE host port per service (below), since
# several instances on one host can't all bind the same host port.
INSTANCE=
# Host ports (defaults below match single-instance). Override per instance:
CANTE_POSTGRES_PORT=5432
CANTE_REDIS_PORT=6379
CANTE_API_PORT=8000
CANTE_INGRESS_PORT=8001
CANTE_EVOLUTION_PORT=8088
CANTE_MOCK_PORT=9000
# The backoffice UI (React/Vite built and served by nginx). This is the URL you
# open in the browser after `make up`: http://localhost:<CANTE_FRONTEND_PORT>.
CANTE_FRONTEND_PORT=5173

# ── App ────────────────────────────────────────
DEBUG=false
DEFAULT_LANGUAGE=en
# Comma-separated allowed CORS origins for the backoffice frontend (S8).
# Empty = same-origin only. Example: https://cante.example.com,https://admin.example.com
CORS_ORIGINS=

# ── Auth (backoffice login + machine tokens) ───
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
# A SEPARATE key for the POST /v1/triggers machine endpoint (NOT the JWT secret).
TRIGGER_API_KEY=
ADMIN_EMAIL=admin@example.com
# Set a real password; the default "change-me" is refused at startup.
ADMIN_PASSWORD=

# ── Database ───────────────────────────────────
POSTGRES_USER=cante
POSTGRES_PASSWORD=
POSTGRES_DB=cante
# Built by compose from the values above; override only for external Postgres.
DATABASE_URL=postgresql+asyncpg://cante:${POSTGRES_PASSWORD}@postgres:5432/cante

# ── Redis ──────────────────────────────────────
# Set REDIS_PASSWORD to enable Redis ACL (S17). Leave empty for local dev only.
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── LLM providers ─────────────────────────────────────────────────────────────
# Up to 5 providers are seeded from these env vars. For each slot:
#   PROVIDER_N_NAME must be non-empty
#   PROVIDER_N_KEY names the env var holding that provider's API key (must be set
#     and non-empty)
#   PROVIDER_N_PARAMS is an optional JSON string, e.g. {"temperature":0.7}
# The seed skips any slot whose key env var is empty or unset — uncomment and
# configure the slots you need.

# Slot 1 — OpenRouter (openai_compatible)
PROVIDER_1_NAME=OpenRouter
PROVIDER_1_TYPE=openai_compatible
PROVIDER_1_BASE_URL=https://openrouter.ai/api/v1
PROVIDER_1_MODEL=anthropic/claude-sonnet-4-20250514
PROVIDER_1_KEY=OPENROUTER_API_KEY

# Slot 2 — Anthropic Direct
# PROVIDER_2_NAME=Anthropic Direct
# PROVIDER_2_TYPE=anthropic
# PROVIDER_2_BASE_URL=https://api.anthropic.com/v1
# PROVIDER_2_MODEL=claude-sonnet-4-20250514
# PROVIDER_2_KEY=ANTHROPIC_API_KEY

# Slot 3 — DeepSeek (openai_compatible)
# PROVIDER_3_NAME=DeepSeek
# PROVIDER_3_TYPE=openai_compatible
# PROVIDER_3_BASE_URL=https://api.deepseek.com/v1
# PROVIDER_3_MODEL=deepseek-chat
# PROVIDER_3_KEY=DEEPSEEK_API_KEY

# Slot 4 — Groq (openai_compatible)
# PROVIDER_4_NAME=Groq
# PROVIDER_4_TYPE=openai_compatible
# PROVIDER_4_BASE_URL=https://api.groq.com/openai/v1
# PROVIDER_4_MODEL=llama-3.3-70b-versatile
# PROVIDER_4_KEY=GROQ_API_KEY

# Slot 5 — LiteLLM proxy (openai_compatible)
# PROVIDER_5_NAME=LiteLLM Proxy
# PROVIDER_5_TYPE=openai_compatible
# PROVIDER_5_BASE_URL=http://litellm:4000/v1
# PROVIDER_5_MODEL=gpt-4o
# PROVIDER_5_KEY=LITELLM_API_KEY

# The actual API keys referenced above:
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
# LITELLM_API_KEY=

# ── Demo (optional — creates a functional Bot + Number + Route) ──────────────
# SEED_DEMO_NUMBER=+351912345678
# SEED_DEMO_PROVIDER=OpenRouter

# ── Evolution API (WhatsApp gateway) ───────────
EVOLUTION_BASE_URL=http://evolution:8080
EVOLUTION_API_KEY=
# Base URL Evolution calls to deliver incoming messages to the cante ingress.
# Default is the single-instance ingress; per-fork override e.g.
# http://cante-cds-ingress:8001 (must be reachable from the Evolution container).
INGRESS_BASE_URL=http://cante-ingress:8001

# ── Secrets encryption (at rest) ───────────────
# MUST be a valid Fernet key. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_ENCRYPTION_KEY=

# ── Observability (optional) ───────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# ── Domain (for production edge proxy) ──────────
PUBLIC_DOMAIN=localhost
