# Cante — environment configuration
# Copy this to .env and fill in your values. Never commit .env.

# ── App ────────────────────────────────────────
DEBUG=false
DEFAULT_LANGUAGE=en

# ── Auth (backoffice login) ────────────────────
JWT_SECRET=change-me-to-a-random-string
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# ── Database ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cante:cante@postgres:5432/cante

# ── Redis ───────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM providers (fallback keys — prefer the Providers page in the backoffice) ─
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Evolution API (WhatsApp gateway) ────────────
EVOLUTION_BASE_URL=http://evolution:8080
EVOLUTION_API_KEY=evolution-secret-key

# ── Secrets encryption ─────────────────────────
SECRET_ENCRYPTION_KEY=change-me-change-me-change-me!

# ── Observability (optional) ────────────────────
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=

# ── Domain (for production edge proxy) ──────────
PUBLIC_DOMAIN=localhost
